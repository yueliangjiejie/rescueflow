# ===================================================================
# RescueFlow 环境变量配置模板
# 复制本文件为 .env 并按需填写:  cp .env.example .env
# 设计原则:未配置的可选服务会自动降级,不影响核心流程启动
# ===================================================================

# ---- 基础 ----
# 运行环境: development | production
NODE_ENV=development
# 后端监听端口
PORT=3000

# ---- 数据库(必填) ----
# MongoDB 连接串,本地默认即可
MONGODB_URI=mongodb://127.0.0.1:27017/rescueflow

# ---- 鉴权 ----
# 生产环境(NODE_ENV=production)必须显式配置,否则启动报错
# 开发环境留空则使用内置默认值
JWT_SECRET=
# JWT 有效期
JWT_EXPIRES_IN=7d

# ---- 微信 H5 登录(可选) ----
# 未配置时降级为匿名/手机号登录
WX_APPID=
WX_SECRET=

# ---- 腾讯地图(可选) ----
# 地图组件用,未配置则地图相关功能不可用
TENCENT_MAP_KEY=

# ---- AI 服务(可选) ----
# 兼容 OpenAI 协议的 API 地址与密钥,未配置则 AI 辅助功能降级
AI_API_BASE=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# ---- 腾讯云 ASR 语音转文字(可选) ----
# 申请: https://console.cloud.tencent.com/asr
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_ASR_APP_ID=

# ---- 对象存储(可选) ----
# 配置了用腾讯云 COS,否则降级为本地磁盘存储
UPLOAD_DIR=./uploads
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-guangzhou

# ---- 前端静态托管(Docker 部署用) ----
# 由后端托管 H5/管理后台编译产物时指定目录
STATIC_H5_DIR=
STATIC_ADMIN_DIR=

# ---- 合规 ----
# 数据保留天数,过期自动清理
DATA_RETENTION_DAYS=365
